PORT=8787

# Optional. If set, requests must include this value in x-alert-secret.
ALERT_SHARED_SECRET=

# SendGrid email delivery. Leave blank to disable email alerts.
SENDGRID_API_KEY=
ALERT_FROM_EMAIL=alerts@example.com
ALERT_FROM_NAME=Canada Job Watcher

# Telegram delivery. Leave blank to disable Telegram alerts.
TELEGRAM_BOT_TOKEN=

# Stripe subscription billing. Keep this secret on the backend only.
STRIPE_SECRET_KEY=sk_live_or_test_key_here
STRIPE_PORTAL_RETURN_URL=https://canadashiftwatcher.netlify.app/